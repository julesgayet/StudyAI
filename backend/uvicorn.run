#!/usr/bin/env bash
# Convenience launcher for the StudyAI backend during local development.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [ ! -d "venv" ]; then
    echo "📦 Création de l'environnement virtuel (backend/venv)..."
    python3 -m venv venv
fi

source venv/bin/activate

echo "⬆️  Mise à jour de pip..."
python -m pip install --upgrade pip >/dev/null

echo "📥 Installation des dépendances backend..."
pip install -e . >/dev/null

if [ ! -f ".env" ]; then
    echo "🧪 Fichier .env manquant. Création depuis env.example."
    cp env.example .env
    echo "⚠️  Modifiez backend/.env pour ajouter votre clé OPENAI_API_KEY puis relancez ce script."
    exit 0
fi

set +u
set -a
source .env
set +a
set -u

if [ -z "${OPENAI_API_KEY:-}" ] || [ "$OPENAI_API_KEY" = "your_openai_api_key_here" ]; then
    echo "❌ OPENAI_API_KEY n'est pas configuré dans backend/.env."
    echo "   Ajoutez votre clé API puis relancez le backend."
    exit 1
fi

HOST="${HOST:-0.0.0.0}"
PORT="${PORT:-8000}"

echo "🚀 Lancement du backend StudyAI sur http://$HOST:$PORT"
exec uvicorn app.main:app --host "$HOST" --port "$PORT" --reload
